# Supabase
# Enable Email provider: Authentication → Providers → Email → toggle ON
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (EUR pricing: Starter €97, Pro €197, Enterprise €397)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring EUR prices in your Stripe dashboard
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PROFESSIONAL_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Vapi.ai
VAPI_API_KEY=your_vapi_api_key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
VAPI_PHONE_NUMBER=+1xxxxxxxxxx

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Cal.com
CAL_API_KEY=your_cal_api_key
NEXT_PUBLIC_CAL_USERNAME=your_cal_username

# Email (Resend) — optional, falls back to console.log in dev
RESEND_API_KEY=re_...
FROM_EMAIL=Anna <noreply@yourdomain.com>

# Google OAuth — set to "true" only after configuring Google in Supabase Auth
# Authentication → Providers → Google → enable + add Client ID/Secret
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Internal API secret — used to secure server-to-server calls (auto-setup, followup)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your_random_secret_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
